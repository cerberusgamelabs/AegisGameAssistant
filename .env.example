# Aegis Game Assistant — environment variables
# Copy this file to .env and fill in your keys.

# Required only if llm.provider = 'anthropic'
ANTHROPIC_API_KEY=

# Required only if llm.provider = 'openai'
OPENAI_API_KEY=

# Optional: override ffplay path if not installed via WinGet
# FFPLAY_PATH=C:\path\to\ffplay.exe
